{
    "name": "ronasit/laravel-chat",
    "description": "This package implements chat functionality based on push notifications.",
    "keywords": [
        "laravel",
        "chat"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Ronas IT",
            "homepage": "https://github.com/RonasIT/laravel-chat/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.4.1",
        "laravel/framework": ">=12.1.1",
        "ronasit/laravel-helpers": ">=3.2",
        "ronasit/laravel-media": "^0.2"
    },
    "autoload": {
        "psr-4": {
            "RonasIT\\Chat\\": "src/"
        },
        "exclude-from-classmap": [
            "tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "RonasIT\\Chat\\Tests\\": "tests/",
            "RonasIT\\Chat\\Tests\\Support\\": "tests/Support/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RonasIT\\Chat\\ChatServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0.1",
        "php-coveralls/php-coveralls": "^2.7",
        "orchestra/testbench": "^10",
        "laravel/pint": "^1.27"
    }
}
